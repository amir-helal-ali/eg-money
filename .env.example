# ===== Eg-Money Environment Variables =====
# Copy this file to `.env` and fill in the values.
# All `*_SECRET` vars MUST be at least 32 characters of random data.
# Generate with: `openssl rand -hex 32` or `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`

# ===== Database =====
DATABASE_URL=file:/home/z/my-project/db/custom.db
# For production, use PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/eg_money?schema=public

# ===== Bootstrap Admin Token =====
# Required for /api/seed endpoint (one-time admin account creation).
# If unset, /api/seed refuses to run. Use `npm run reset-admin` instead for CLI.
BOOTSTRAP_ADMIN_TOKEN=replace_with_32_plus_char_random_string

# ===== Internal Secret (Next.js ↔ ticker-service) =====
# Required for all ticker-service HTTP endpoints (except public GET /price).
# Both the Next.js app and ticker-service must use the SAME value.
INTERNAL_SECRET=replace_with_32_plus_char_random_string

# ===== Cron Secret (ticker-service → Next.js cron endpoints) =====
# Required for /api/price-alerts/check and /api/p2p/cleanup-expired.
# Both the Next.js app and ticker-service must use the SAME value.
CRON_SECRET=replace_with_32_plus_char_random_string

# ===== Allowed Origins (WebSocket CORS) =====
# Comma-separated list of origins allowed to connect to the ticker-service WebSocket.
# Defaults to http://localhost:3000 for dev.
# Example: https://eg-money.com,https://www.eg-money.com
ALLOWED_ORIGINS=http://localhost:3000

# ===== Public Base URL =====
# Used for sitemap, OG images, and absolute URL generation.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ===== Email (nodemailer) =====
# Configure for production email delivery (OTP, security alerts, etc.).
# If unset, emails are logged to console only (dev mode).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Eg-Money <noreply@eg-money.com>"

# ===== VAPID Keys (Web Push Notifications) =====
# Generate with: `npx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@eg-money.com

# ===== Google OAuth (admin-managed) =====
# These are stored in the Settings table and managed via admin UI.
# Optional — leave unset to disable Google login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
